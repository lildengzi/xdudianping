<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.sens.mapper.MarkMapper">
    <sql id="tableName">
        biz_mark
    </sql>

    <sql id="baseColumn">
        id,user_id,main_type,main_id,create_time
    </sql>



    <select id="countByUserId" resultType="java.lang.Integer">
        SELECT
            count(*)
        FROM
            biz_mark
        WHERE
            main_type = #{type} and main_id IN ( SELECT id FROM biz_note WHERE user_id = #{userId} )
    </select>

</mapper>